<%= render "shared/error_messages", object: appointment %>

<%= form_with(model: appointment) do |f| %>
  <div class="mb-3">
    <%= f.label :pet_id, "Pet", class: "form-label" %>
    <%= f.collection_select :pet_id, Pet.all, :id, :name, { prompt: "Select pet" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :vet_id, "Veterinarian", class: "form-label" %>
    <%= f.collection_select :vet_id, Vet.all, :id, :first_name, { prompt: "Select vet" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :date, class: "form-label" %>
    <%= f.datetime_field :date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :reason, class: "form-label" %>
    <%= f.text_area :reason, class: "form-control", rows: 3 %>
  </div>

  <div class="mb-3">
    <%= f.label :status, class: "form-label" %>
    <%= f.select :status, Appointment.statuses.keys.map { |s| [s.humanize, s] }, { prompt: "Select status" }, class: "form-select" %>
  </div>

  <%= f.submit class: "btn btn-success" %>
  <%= link_to "Cancel", appointments_path, class: "btn btn-outline-secondary ms-2" %>
<% end %>

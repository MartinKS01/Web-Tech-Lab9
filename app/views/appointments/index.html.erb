<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Appointments</h1>
  <%= link_to "New Appointment", new_appointment_path, class: "btn btn-success" %>
</div>

<table class="table table-bordered table-hover bg-white shadow-sm">
  <thead class="table-success">
    <tr>
      <th>Date</th>
      <th>Pet</th>
      <th>Vet</th>
      <th>Reason</th>
      <th>Status</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @appointments.each do |appointment| %>
      <% status_colors = { "scheduled" => "primary", "in_progress" => "warning", "completed" => "success", "cancelled" => "danger" } %>
      <tr>
        <td><%= link_to appointment.date.strftime("%B %d, %Y %H:%M"), appointment_path(appointment) %></td>
        <td><%= link_to appointment.pet.name, pet_path(appointment.pet) %></td>
        <td><%= link_to "#{appointment.vet.first_name} #{appointment.vet.last_name}", vet_path(appointment.vet) %></td>
        <td><%= appointment.reason %></td>
        <td>
          <span class="badge bg-<%= status_colors[appointment.status] %>">
            <%= appointment.status.humanize %>
          </span>
        </td>
        <td>
          <%= link_to "Edit", edit_appointment_path(appointment), class: "btn btn-sm btn-outline-primary me-1" %>
          <%= button_to "Delete", appointment_path(appointment), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="mb-3">
  <%= link_to "← Back to Vets", vets_path, class: "btn btn-outline-secondary btn-sm" %>
  <% if policy(@vet).update? %>
    <%= link_to "Edit", edit_vet_path(@vet), class: "btn btn-outline-primary btn-sm ms-2" %>
  <% end %>
  <% if policy(@vet).destroy? %>
    <%= button_to "Delete", vet_path(@vet), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm ms-2" %>
  <% end %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-success text-white">
    <h2 class="h5 mb-0"><%= "#{@vet.first_name} #{@vet.last_name}" %></h2>
  </div>
  <ul class="list-group list-group-flush">
    <li class="list-group-item"><strong>Email:</strong> <%= @vet.email %></li>
    <li class="list-group-item"><strong>Phone:</strong> <%= @vet.phone %></li>
    <li class="list-group-item"><strong>Specialization:</strong> <%= @vet.specialization %></li>
  </ul>
</div>

<h4>Upcoming Appointments</h4>
<% upcoming = @vet.appointments.upcoming %>
<% if upcoming.any? %>
  <table class="table table-bordered table-hover bg-white shadow-sm mb-4">
    <thead class="table-success">
      <tr><th>Date</th><th>Pet</th><th>Reason</th><th>Status</th></tr>
    </thead>
    <tbody>
      <% upcoming.each do |appointment| %>
        <tr>
          <td><%= link_to appointment.date.strftime("%B %d, %Y %H:%M"), appointment_path(appointment) %></td>
          <td><%= link_to appointment.pet.name, pet_path(appointment.pet) %></td>
          <td><%= appointment.reason %></td>
          <td><span class="badge bg-primary"><%= appointment.status.humanize %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No upcoming appointments.</p>
<% end %>

<h4>Past Appointments</h4>
<% past = @vet.appointments.past %>
<% if past.any? %>
  <% status_colors = { "scheduled" => "primary", "in_progress" => "warning", "completed" => "success", "cancelled" => "danger" } %>
  <table class="table table-bordered table-hover bg-white shadow-sm">
    <thead class="table-secondary">
      <tr><th>Date</th><th>Pet</th><th>Reason</th><th>Status</th></tr>
    </thead>
    <tbody>
      <% past.each do |appointment| %>
        <tr>
          <td><%= link_to appointment.date.strftime("%B %d, %Y %H:%M"), appointment_path(appointment) %></td>
          <td><%= link_to appointment.pet.name, pet_path(appointment.pet) %></td>
          <td><%= appointment.reason %></td>
          <td><span class="badge bg-<%= status_colors[appointment.status] %>"><%= appointment.status.humanize %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No past appointments.</p>
<% end %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Veterinarians</h1>
  <% if policy(Vet).create? %>
    <%= link_to "New Vet", new_vet_path, class: "btn btn-success" %>
  <% end %>
</div>

<table class="table table-bordered table-hover bg-white shadow-sm">
  <thead class="table-success">
    <tr>
      <th>Full Name</th>
      <th>Email</th>
      <th>Specialization</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @vets.each do |vet| %>
      <tr>
        <td><%= link_to "#{vet.first_name} #{vet.last_name}", vet_path(vet) %></td>
        <td><%= vet.email %></td>
        <td><%= vet.specialization %></td>
        <td>
          <% if policy(vet).update? %>
            <%= link_to "Edit", edit_vet_path(vet), class: "btn btn-sm btn-outline-primary me-1" %>
          <% end %>
          <% if policy(vet).destroy? %>
            <%= button_to "Delete", vet_path(vet), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0">Pets</h1>
  <%= link_to "New Pet", new_pet_path, class: "btn btn-success" %>
</div>

<table class="table table-bordered table-hover bg-white shadow-sm">
  <thead class="table-success">
    <tr>
      <th>Photo</th>
      <th>Name</th>
      <th>Species</th>
      <th>Breed</th>
      <th>Owner</th>
      <th>Date of Birth</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @pets.each do |pet| %>
      <tr>
        <td>
          <% if pet.photo.attached? %>
            <%= image_tag pet.photo, width: 60, height: 60, class: "rounded", style: "object-fit: cover;" %>
          <% else %>
            <div class="bg-light border rounded d-flex align-items-center justify-content-center" style="width:60px;height:60px;">
              <small class="text-muted">N/A</small>
            </div>
          <% end %>
        </td>
        <td><%= link_to pet.name, pet_path(pet) %></td>
        <td><%= pet.species.capitalize %></td>
        <td><%= pet.breed %></td>
        <td><%= pet.owner ? link_to("#{pet.owner.first_name} #{pet.owner.last_name}", owner_path(pet.owner)) : "No owner" %></td>
        <td><%= pet.date_of_birth.strftime("%B %d, %Y") %></td>
        <td>
          <%= link_to "Edit", edit_pet_path(pet), class: "btn btn-sm btn-outline-primary me-1" %>
          <%= button_to "Delete", pet_path(pet), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="mb-3">
  <%= link_to "← Back to Pets", pets_path, class: "btn btn-outline-secondary btn-sm" %>
  <% if policy(@pet).update? %>
    <%= link_to "Edit", edit_pet_path(@pet), class: "btn btn-outline-primary btn-sm ms-2" %>
  <% end %>
  <% if policy(@pet).destroy? %>
    <%= button_to "Delete", pet_path(@pet), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm ms-2" %>
  <% end %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-success text-white">
    <h2 class="h5 mb-0"><%= @pet.name %></h2>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-3 text-center mb-3">
        <% if @pet.photo.attached? %>
          <%= image_tag @pet.photo, width: 300, class: "img-fluid rounded shadow-sm" %>
        <% else %>
          <div class="bg-light border rounded d-flex align-items-center justify-content-center" style="width:300px;height:300px;">
            <span class="text-muted">No photo available</span>
          </div>
        <% end %>
      </div>
      <div class="col-md-9">
        <ul class="list-group list-group-flush">
          <li class="list-group-item"><strong>Species:</strong> <%= @pet.species.capitalize %></li>
          <li class="list-group-item"><strong>Breed:</strong> <%= @pet.breed %></li>
          <li class="list-group-item"><strong>Date of Birth:</strong> <%= @pet.date_of_birth.strftime("%B %d, %Y") %></li>
          <li class="list-group-item"><strong>Weight:</strong> <%= @pet.weight %> kg</li>
          <li class="list-group-item"><strong>Owner:</strong> <%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", owner_path(@pet.owner) %></li>
        </ul>
      </div>
    </div>
  </div>
</div>

<h4>Upcoming Appointments</h4>
<% upcoming = @pet.appointments.upcoming %>
<% if upcoming.any? %>
  <table class="table table-bordered table-hover bg-white shadow-sm mb-4">
    <thead class="table-success">
      <tr><th>Date</th><th>Reason</th><th>Status</th></tr>
    </thead>
    <tbody>
      <% upcoming.each do |appointment| %>
        <tr>
          <td><%= link_to appointment.date.strftime("%B %d, %Y %H:%M"), appointment_path(appointment) %></td>
          <td><%= appointment.reason %></td>
          <td><span class="badge bg-primary"><%= appointment.status.humanize %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No upcoming appointments.</p>
<% end %>

<h4>Past Appointments</h4>
<% past = @pet.appointments.past %>
<% if past.any? %>
  <% status_colors = { "scheduled" => "primary", "in_progress" => "warning", "completed" => "success", "cancelled" => "danger" } %>
  <table class="table table-bordered table-hover bg-white shadow-sm">
    <thead class="table-secondary">
      <tr><th>Date</th><th>Reason</th><th>Status</th></tr>
    </thead>
    <tbody>
      <% past.each do |appointment| %>
        <tr>
          <td><%= link_to appointment.date.strftime("%B %d, %Y %H:%M"), appointment_path(appointment) %></td>
          <td><%= appointment.reason %></td>
          <td><span class="badge bg-<%= status_colors[appointment.status] %>"><%= appointment.status.humanize %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No past appointments.</p>
<% end %>

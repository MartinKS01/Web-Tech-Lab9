<%= render "shared/error_messages", object: pet %>

<%= form_with(model: pet) do |f| %>
  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :species, class: "form-label" %>
    <%= f.select :species, Pet::SPECIES.map { |s| [s.capitalize, s] }, { prompt: "Select species" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :breed, class: "form-label" %>
    <%= f.text_field :breed, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :date_of_birth, class: "form-label" %>
    <%= f.date_field :date_of_birth, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :weight, "Weight (kg)", class: "form-label" %>
    <%= f.number_field :weight, step: 0.1, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :owner_id, "Owner", class: "form-label" %>
    <%= f.collection_select :owner_id, Owner.all, :id, :first_name, { prompt: "Select owner" }, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :photo, class: "form-label" %>
    <% if pet.persisted? && pet.photo.attached? %>
      <div class="mb-2">
        <p class="text-muted small">Current photo:</p>
        <%= image_tag pet.photo, width: 100, class: "rounded border" %>
      </div>
    <% end %>
    <%= f.file_field :photo, class: "form-control", accept: "image/jpeg,image/png,image/webp" %>
    <div class="form-text">Optional. JPEG, PNG, or WebP. Max 5MB.</div>
  </div>

  <%= f.submit class: "btn btn-success" %>
  <%= link_to "Cancel", pets_path, class: "btn btn-outline-secondary ms-2" %>
<% end %>

<div class="mb-3">
  <%= link_to "← Back to Owners", owners_path, class: "btn btn-outline-secondary btn-sm" %>
  <% if policy(@owner).update? %>
    <%= link_to "Edit", edit_owner_path(@owner), class: "btn btn-outline-primary btn-sm ms-2" %>
  <% end %>
  <% if policy(@owner).destroy? %>
    <%= button_to "Delete", owner_path(@owner), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-outline-danger btn-sm ms-2" %>
  <% end %>
</div>

<div class="card shadow-sm mb-4">
  <div class="card-header bg-success text-white">
    <h2 class="h5 mb-0"><%= "#{@owner.first_name} #{@owner.last_name}" %></h2>
  </div>
  <ul class="list-group list-group-flush">
    <li class="list-group-item"><strong>Email:</strong> <%= @owner.email %></li>
    <li class="list-group-item"><strong>Phone:</strong> <%= @owner.phone %></li>
    <li class="list-group-item"><strong>Address:</strong> <%= @owner.address %></li>
  </ul>
</div>

<h4>Pets</h4>
<% if @owner.pets.any? %>
  <table class="table table-bordered table-hover bg-white shadow-sm">
    <thead class="table-success">
      <tr>
        <th>Name</th>
        <th>Species</th>
        <th>Breed</th>
      </tr>
    </thead>
    <tbody>
      <% @owner.pets.each do |pet| %>
        <tr>
          <td><%= link_to pet.name, pet_path(pet) %></td>
          <td><%= pet.species %></td>
          <td><%= pet.breed %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="text-muted">No pets registered.</p>
<% end %>
